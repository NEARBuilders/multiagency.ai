# Generated from configured bos secrets
# Update values as needed for your local environment

API_DATABASE_URL=postgres://multiagency:multiagency@localhost:5432/api_db
AUTH_DATABASE_URL=postgres://multiagency:multiagency@localhost:5433/auth_db
APPLICATIONS_WEBHOOK_URL=
RESEND_API_KEY=
NOTIFY_FROM_EMAIL=
BETTER_AUTH_SECRET=
# Pin to a single network (hides the NetworkToggle UI; every visitor sees this
# network). Leave unset for multi-network mode — visitors (anonymous or
# signed-in) toggle between mainnet and testnet via NetworkToggle.
NEAR_NETWORK=
# Per-network maintainer defaults — visitor's resolved view network selects one.
AGENCY_ORG_ACCOUNT_MAINNET=multiagency.sputnik-dao.near
AGENCY_ORG_ACCOUNT_TESTNET=multiagency.sputnikv2.testnet
# Optional private-RPC overrides (per-network — public fastnear endpoints
# route correctly per-account by default).
NEAR_RPC_URL_MAINNET=
NEAR_RPC_URL_TESTNET=
# Lifts rate limits on fastnear RPC + REST endpoints; sent as Bearer auth only
# when the destination host is fastnear (never leaked to private-RPC overrides).
FASTNEAR_API_KEY=
# Agency operational-identity overrides (fork-specific). These are env-level
# fallbacks; the `agency.settings` row (keyed by orgAccountId, edited via
# /admin/settings) takes precedence — resolution order is DB row → env →
# hardcoded. Brand identity (name / headline / tagline) is truly invariant —
# fork settings-defaults.ts to change those (no env hook).
AGENCY_WEBSITE_URL=
AGENCY_DOCS_URL=
AGENCY_DESCRIPTION=
AGENCY_NEARN_ACCOUNT=
AGENCY_CONTACT_EMAIL=
# DAO role names — defaults match Trezu's role convention. The Sputnik factory
# itself defaults to `all`/`council`; override here if your DAO uses those or
# any other non-standard names.
AGENCY_ADMIN_ROLE=
AGENCY_APPROVER_ROLE=
AGENCY_REQUESTOR_ROLE=
CORS_ORIGIN=http://localhost:3000
PROJECTS_DATABASE_URL=postgres://multiagency:multiagency@localhost:5434/projects_db
