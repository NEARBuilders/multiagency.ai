{
  "name": "monorepo",
  "private": true,
  "workspaces": {
    "packages": [
      "api",
      "ui",
      "plugins/*"
    ],
    "catalog": {
      "react": "19.2.4",
      "react-dom": "19.2.4",
      "@tanstack/react-query": "5.90.20",
      "@tanstack/react-router": "1.157.16",
      "@tanstack/react-router-devtools": "1.157.16",
      "@tanstack/router-plugin": "1.157.16",
      "near-kit": "^0.14.0",
      "@hot-labs/near-connect": "^0.11.0",
      "drizzle-orm": "^0.45.1",
      "drizzle-kit": "^0.31.8",
      "better-auth": "1.6.9",
      "better-near-auth": "1.6.3",
      "every-plugin": "^2.7.1",
      "typescript": "^5.9.3",
      "vitest": "^4.1.8",
      "@types/node": "^25.0.3",
      "@types/react": "^19.2.7",
      "@types/react-dom": "^19.2.3",
      "effect": "3.21.2",
      "@module-federation/enhanced": "^2.4.0",
      "@module-federation/node": "^2.7.42",
      "@module-federation/rsbuild-plugin": "^2.4.0",
      "@module-federation/runtime-core": "^2.4.0",
      "@module-federation/sdk": "^2.4.0",
      "@module-federation/dts-plugin": "^2.4.0",
      "zod": "4.3.6",
      "@orpc/contract": "1.14.3",
      "@better-auth/api-key": "1.6.9",
      "@better-auth/passkey": "1.6.9",
      "everything-dev": "^1.42.2",
      "@scure/base": "^2.2.0",
      "pg": "^8.12.0",
      "@types/pg": "^8.11.6",
      "@electric-sql/pglite": "^0.4.5",
      "@orpc/server": "1.14.3",
      "@orpc/client": "1.14.3",
      "@orpc/zod": "1.14.3",
      "@orpc/openapi": "1.14.3",
      "@tanstack/intent": "^0.3.5",
      "@opentelemetry/api": "^1.9.0",
      "@rspack/core": "1.7.11",
      "@rspack/cli": "1.7.11",
      "@rsbuild/core": "1.7.5",
      "@rsbuild/plugin-react": "1.4.6",
      "@libsql/client": "0.17.0",
      "@tanstack/react-query-devtools": "^5.91.1",
      "@tanstack/react-devtools": "^0.10.1",
      "@tanstack/react-form": "^1.29.1",
      "@tanstack/react-table": "^8.21.3",
      "zephyr-rspack-plugin": "^1.1.1",
      "zephyr-rsbuild-plugin": "^1.1.1",
      "@tanstack/zod-form-adapter": "^0.42.1",
      "@better-auth/core": "1.6.9",
      "@orpc/tanstack-query": "1.14.3"
    }
  },
  "scripts": {
    "dev": "node_modules/.bin/bos dev",
    "dev:ui": "node_modules/.bin/bos dev --ui local --api remote",
    "dev:api": "node_modules/.bin/bos dev --ui remote --api local",
    "dev:proxy": "node_modules/.bin/bos dev --proxy",
    "build": "node_modules/.bin/bos build",
    "deploy": "node_modules/.bin/bos build --deploy",
    "publish": "node_modules/.bin/bos publish",
    "typecheck": "bun run types:gen && if [ -d ui ]; then bun run --cwd ui typecheck; fi && if [ -d api ]; then bun run --cwd api typecheck; fi && if [ -d plugins ]; then for dir in plugins/*; do if [ -f \"$dir/package.json\" ]; then bun run --cwd \"$dir\" typecheck; fi; done; fi",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "start": "node_modules/.bin/bos start",
    "db:push": "bun run --cwd api drizzle-kit push",
    "db:studio": "node_modules/.bin/bos db:studio",
    "db:generate": "bun run --cwd api drizzle-kit generate",
    "db:migrate": "bun run --cwd api drizzle-kit migrate",
    "types:gen": "node_modules/.bin/bos types gen",
    "postinstall": "node_modules/.bin/bos types gen || true",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "echo 'Packages versioned - app release handled by workflow'",
    "test": "bun run test:api",
    "test:api": "cd api && bun run test tests/integration/ tests/unit/",
    "test:integration": "cd api && bun run test tests/integration/",
    "test:ui": "cd ui && bun run test",
    "dev:postgres": "docker compose up -d --wait && bun run dev",
    "dev:postgres:down": "docker compose down",
    "dev:postgres:reset": "docker compose down -v && docker compose up -d --wait",
    "bos": "node_modules/.bin/bos"
  },
  "packageManager": "bun@1.2.20",
  "type": "module",
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@types/bun": "latest",
    "dotenv": "^17.3.1",
    "tsx": "^4.21.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "catalog:",
    "@changesets/cli": "^2.29.8"
  },
  "dependencies": {
    "@electric-sql/pglite": "catalog:",
    "@orpc/contract": "catalog:",
    "better-near-auth": "catalog:",
    "every-plugin": "catalog:",
    "everything-dev": "catalog:",
    "@better-auth/api-key": "catalog:",
    "@better-auth/passkey": "catalog:",
    "@hot-labs/near-connect": "0.11.2",
    "@orpc/server": "catalog:",
    "better-auth": "catalog:",
    "drizzle-orm": "catalog:",
    "effect": "catalog:",
    "zod": "catalog:",
    "@opentelemetry/api": "catalog:",
    "@libsql/client": "catalog:",
    "@better-auth/core": "catalog:"
  }
}
