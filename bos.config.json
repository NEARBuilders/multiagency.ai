{
  "extends": "bos://dev.everything.near/dev.everything.dev",
  "account": "multiagentic.near",
  "domain": "dev.multiagency.ai",
  "title": "MultiAgency",
  "description": "Human-led, AI-native agencies for hire.",
  "testnet": "agency.testnet",
  "staging": {
    "domain": "dev.multiagency.ai"
  },
  "repository": "https://github.com/MultiAgency/dashboard",
  "app": {
    "ui": {
      "name": "ui",
      "development": "local:ui"
    },
    "api": {
      "name": "api",
      "development": "local:api",
      "secrets": [
        "API_DATABASE_URL",
        "APPLICATIONS_WEBHOOK_URL",
        "RESEND_API_KEY",
        "NOTIFY_FROM_EMAIL",
        "FASTNEAR_API_KEY"
      ]
    }
  },
  "plugins": {
    "projects": {
      "development": "local:plugins/projects",
      "secrets": [
        "PROJECTS_DATABASE_URL"
      ],
      "routes": [
        "ui/src/routes/_layout/_authenticated/projects/**"
      ],
      "sidebar": [
        {
          "icon": "FolderKanban",
          "label": "projects"
        }
      ]
    }
  }
}
